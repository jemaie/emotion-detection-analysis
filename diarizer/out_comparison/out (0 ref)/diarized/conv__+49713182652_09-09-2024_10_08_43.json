      "text": " erste schwerbehinderte Parkausweis?",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_41",
      "end": 108.962,
      "speaker": "A",
      "start": 106.012,
      "text": " Also ein behinderter Ausweis hat sie schon länger,",
      "type": "transcript.text.segment"
    },
