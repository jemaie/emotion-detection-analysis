      "end": 0.6000000000000001,
      "speaker": "A",
      "start": 0.0,
      "text": " Grüß Gott,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_1",
      "end": 6.15,
      "speaker": "A",
      "start": 0.7000000000000002,
      "text": " ich möchte für meine Mutter einen behinderten Parkausweis beantragen.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_2",
      "end": 14.046,
      "speaker": "A",
      "start": 6.996,
      "text": " Das habe ich gelesen, ich brauche Vollmacht. Dazu muss was Bestimmtes drinstehen oder bestimmtes Formular sein oder kann sie das freischreiben.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_3",
      "end": 15.946000000000002,
      "speaker": "B",
      "start": 14.346,
      "text": " Das könnte er freischreiben.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_4",
      "end": 19.096,
      "speaker": "B",
      "start": 16.146,
      "text": " Es ist nicht sie bevollmächtigt und ja.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_5",
      "end": 19.945999999999998,
      "speaker": "A",
      "start": 19.096,
      "text": " Ja, aha.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_6",
      "end": 22.646,
      "speaker": "A",
      "start": 20.445999999999998,
      "text": " Und ein Passbild steht drin,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_7",
      "end": 23.396,
      "speaker": "A",
      "start": 22.746000000000002,
      "text": " braucht man.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_8",
      "end": 31.495999999999995,
      "speaker": "A",
      "start": 24.296,
      "text": " Müsste jetzt erst machen lassen oder sehen Sie Zugriff auf die Passbilder vom Personalausweis und könnte sie das nehmen.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_9",
      "end": 33.596,
      "speaker": "B",
      "start": 31.895999999999994,
      "text": " Nein, nein, das kann man nicht nehmen.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_10",
      "end": 34.012,
      "speaker": "A",
      "start": 33.961999999999996,
      "text": " Okay.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_11",
      "end": 36.512,
      "speaker": "B",
      "start": 34.012,
      "text": " Aber ihr müsst eh geschwind abklären.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_12",
      "end": 38.611999999999995,
      "speaker": "B",
      "start": 37.361999999999995,
      "text": " Kleinen Moment,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_13",
      "end": 39.762,
      "speaker": "B",
      "start": 38.861999999999995,
      "text": " ich muss mal geschwind fragen.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_14",
      "end": 56.762,
      "speaker": "B",
      "start": 54.711999999999996,
      "text": " Ja, wegen schneller Deutsch machen sie.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_15",
      "end": 65.506,
      "speaker": "B",
      "start": 64.756,
      "text": " Hallo, bitte.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_16",
      "end": 66.156,
      "speaker": "A",
      "start": 65.656,
      "text": " Ja.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_17",
      "end": 68.506,
      "speaker": "B",
      "start": 66.556,
      "text": " Geht schriftlich, sagt gerade unser Chef.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_18",
      "end": 71.562,
      "speaker": "B",
      "start": 69.812,
      "text": " Sie können die Vollmachten beilegen,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_19",
      "end": 74.012,
      "speaker": "B",
      "start": 71.612,
      "text": " einen Bild beilegen, einen",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_20",
      "end": 75.962,
      "speaker": "A",
      "start": 74.012,
      "text": " Das heißt, die müssen wir nicht einmal selber kommen?",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_21",
      "end": 76.712,
      "speaker": "B",
      "start": 76.012,
      "text": " Aus... Nein, nee,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_22",
