      "id": "seg_23",
      "end": 77.16199999999999,
      "speaker": "B",
      "start": 76.862,
      "text": " die können",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_24",
      "end": 77.212,
      "speaker": "A",
      "start": 77.16199999999999,
      "text": " perfekt.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_25",
      "end": 77.712,
      "speaker": "B",
      "start": 77.212,
      "text": " wir so...",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_26",
      "end": 81.962,
      "speaker": "A",
      "start": 77.712,
      "text": " Gut, dann gucke ich, dass wir Bilder machen. Das kann jetzt natürlich ein bisschen dauern.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_27",
      "end": 83.012,
      "speaker": "B",
      "start": 81.962,
      "text": " Ja, klar.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_28",
      "end": 83.162,
      "speaker": "A",
      "start": 83.012,
      "text": " Ja.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_29",
      "end": 90.362,
      "speaker": "B",
      "start": 83.162,
      "text": " Und dann können Sie so eine Rathausbriefkastenwerbe zu ihrem Bürgerbüro und dann, die sind ausgestellt.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_30",
      "end": 93.412,
      "speaker": "A",
      "start": 90.612,
      "text": " Ach so, aber Sie brauchen doch den Behindertenausweis.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_31",
      "end": 96.262,
      "speaker": "B",
      "start": 93.812,
      "text": " Ja, den in Kopie beilegen.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_32",
      "end": 97.562,
      "speaker": "A",
      "start": 96.262,
      "text": " Ach, eine Kopie. Okay.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_33",
      "end": 97.748,
      "speaker": "A",
      "start": 97.748,
      "text": " Okay.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_34",
