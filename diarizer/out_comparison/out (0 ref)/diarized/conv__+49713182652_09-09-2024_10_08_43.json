      "id": "seg_42",
      "end": 115.012,
      "speaker": "A",
      "start": 109.012,
      "text": " aber jetzt hat sie 100% uns AG bekommen und jetzt möchte sie natürlich den Parkausweis,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_43",
      "end": 117.312,
      "speaker": "A",
