    },
    {
      "id": "seg_3",
      "end": 6.8999999999999995,
      "speaker": "B",
      "start": 4.8,
      "text": " Und zwar wollte ich ja den Herrn Knapp sprechen.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_4",
      "end": 9.950000000000001,
      "speaker": "B",
      "start": 7.05,
      "text": " Ich hatte jetzt schon ein paar Mal probiert. Ist der sicher heute im Haus?",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_5",
      "end": 12.3,
      "speaker": "A",
      "start": 10.8,
      "text": " Der ist da wahrscheinlich.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_6",
      "end": 14.3,
      "speaker": "A",
      "start": 12.600000000000001,
      "text": " Ja, gesehen habe ich ihn noch nicht,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_7",
      "end": 16.3,
      "speaker": "A",
      "start": 14.4,
      "text": " aber die sind halt viel draußen unterwegs.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_8",
      "end": 20.8,
      "speaker": "A",
      "start": 17.150000000000002,
      "text": " Herr Knapp gehört ja zum Ordnungsamt und der Herr guckt ja draußen.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_9",
      "end": 23.25,
      "speaker": "B",
      "start": 21.2,
      "text": " Ja, hat der dann eine Handynummer,",
