    },
    {
      "id": "seg_11",
      "end": 28.979999999999997,
      "speaker": "A",
      "start": 27.18,
      "text": " hat, ich sehe ihn nicht da.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_12",
      "end": 32.879999999999995,
      "speaker": "A",
      "start": 29.029999999999998,
      "text": " Ich habe eine Telefonnummer noch von Heilbronn.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_13",
      "end": 36.23,
      "speaker": "A",
      "start": 35.129999999999995,
      "text": " Tja, einen Moment.",
