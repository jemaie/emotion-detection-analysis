    },
    {
      "id": "seg_1",
      "end": 4.8999999999999995,
      "speaker": "B",
      "start": 1.5000000000000002,
      "text": " Konkret gesagt, ich hätte gerne die IRV-Stelle Frau Nagel.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_2",
      "end": 8.5,
      "speaker": "A",
      "start": 5.8999999999999995,
      "text": " Frau Nagel ist momentan bei uns nicht im Haus.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_3",
      "end": 11.5,
      "speaker": "B",
      "start": 9.1,
      "text": " Und jemand anderes von der IRV-Stelle?",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_4",
      "end": 16.85,
      "speaker": "A",
      "start": 12.75,
      "text": " Müsste ich mal geschwind gucken, weil eigentlich hat sie gar keine Vertretung.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_5",
      "end": 18.45,
      "speaker": "B",
      "start": 18.05,
      "text": " Okay,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_6",
      "end": 20.75,
      "speaker": "B",
      "start": 18.65,
      "text": " und braucht man dann einen Termin, wenn man was machen will?",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_7",
      "end": 24.33,
      "speaker": "A",
      "start": 23.38,
      "text": " Wie meinen Sie?",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_8",
      "end": 26.779999999999998,
      "speaker": "B",
      "start": 24.529999999999998,
      "text": " Wenn wir einen Anliegen haben, wie kann",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_9",
      "end": 26.83,
      "speaker": "A",
      "start": 26.779999999999998,
      "text": " Man",
