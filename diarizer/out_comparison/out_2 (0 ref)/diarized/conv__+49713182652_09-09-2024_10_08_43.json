      "end": 0.55,
      "speaker": "A",
      "start": 0.0,
      "text": " Grüß Gott,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_1",
      "end": 6.15,
      "speaker": "A",
      "start": 0.7,
      "text": " ich möchte für meine Mutter einen Behindertenparkausweis beantragen.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_2",
      "end": 14.046,
      "speaker": "A",
      "start": 6.996,
      "text": " Das habe ich gelesen, ich brauche Vollmacht. Dazu muss was Bestimmtes drinstehen oder bestimmtes Formular sein oder kann Sie das freischreiben?",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_3",
      "end": 15.946000000000002,
      "speaker": "B",
      "start": 14.346,
      "text": " Das könnt ihr ja freischreiben.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_4",
      "end": 19.096000000000004,
      "speaker": "B",
      "start": 16.046,
      "text": " Es ist auch ziemlich bevollmächtigt und ja.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_5",
      "end": 19.996000000000002,
      "speaker": "A",
      "start": 19.096000000000004,
      "text": " Ja, aha.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_6",
      "end": 23.396,
      "speaker": "A",
      "start": 20.396,
      "text": " Wenn ein Passbild steht drin braucht man,",
