    },
    {
      "id": "seg_26",
      "end": 65.418,
      "speaker": "A",
      "start": 64.868,
      "text": " ja,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_27",
      "end": 66.068,
      "speaker": "agent",
      "start": 65.418,
      "text": " das tut mir leid.",
