    },
    {
      "id": "seg_30",
      "end": 73.946,
      "speaker": "A",
      "start": 73.396,
      "text": " Tüd,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_31",
      "end": 75.846,
      "speaker": "A",
      "start": 74.046,
      "text": " biep, biep, biep. Also ich habe gesagt,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_32",
      "end": 78.446,
      "speaker": "A",
      "start": 75.896,
      "text": " wo bin ich denn? Bin ich hier in der Steinzeit angekommen?",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_33",
      "end": 80.396,
      "speaker": "A",
      "start": 78.546,
      "text": " Also das hört sich nicht gut an.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_34",
      "end": 82.246,
      "speaker": "A",
      "start": 80.796,
      "text": " Jetzt würde ich Sie bitten,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_35",
      "end": 88.29599999999999,
      "speaker": "A",
      "start": 82.346,
      "text": " ich möchte jemand von den Wasseraufbereitungs-Spezialisten, also vom Wasserwerk jemand,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_36",
      "end": 89.196,
      "speaker": "A",
      "start": 88.396,
      "text": " der Ahnung hat,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_37",
      "end": 97.24600000000001,
      "speaker": "A",
      "start": 89.296,
      "text": " der was über Filterweise oder über Levanidfilter, über Ionenaustauscher, über Eppoxid hat und das gehört alles zur Wasser dazu.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_38",
      "end": 100.99600000000001,
      "speaker": "agent",
      "start": 97.24600000000001,
      "text": " Ich denke, das sind dann die Regionalwerke, der Betrieb.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_39",
      "end": 101.296,
      "speaker": "A",
      "start": 100.99600000000001,
      "text": " Ja,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_40",
      "end": 101.896,
      "speaker": "A",
      "start": 101.396,
      "text": " ja.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_41",
      "end": 104.89999999999999,
      "speaker": "agent",
      "start": 102.1,
      "text": " Um die, die Wochenende was für Ohrentausche und wo die Anlage,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_42",
      "end": 107.1,
      "speaker": "A",
      "start": 104.89999999999999,
      "text": " Ja, ja, die Wasseruhrentauschen,",
      "type": "transcript.text.segment"
    },
