    },
    {
      "id": "seg_24",
      "end": 64.618,
      "speaker": "A",
      "start": 64.118,
      "text": " Ach, jetzt so geht,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_25",
      "end": 64.868,
      "speaker": "agent",
      "start": 64.618,
      "text": " liebe Zeit,",
