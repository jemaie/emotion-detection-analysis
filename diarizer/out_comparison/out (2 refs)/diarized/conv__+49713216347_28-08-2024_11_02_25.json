  "segments": [
    {
      "id": "seg_0",
      "end": 0.7500000000000002,
      "speaker": "agent",
      "start": 0.0,
      "text": " Du hast wohl gesagt.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_1",
      "end": 3.5999999999999996,
      "speaker": "A",
      "start": 1.2500000000000002,
      "text": " Ja, Lache in Ehrenbach, guten Morgen.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_2",
      "end": 8.3,
      "speaker": "A",
      "start": 4.7,
      "text": " Also ich bin ja normalerweise freudig aufgelegt,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_3",
      "end": 15.150000000000002,
      "speaker": "A",
      "start": 8.4,
      "text": " aber was ich erlebt habe mit Ihrer Anlage, mit Ihrer Telefonanlage, um überhaupt mal in die Stadt näher gesund zu kommen,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_4",
      "end": 24.150000000000002,
      "speaker": "A",
      "start": 15.3,
      "text": " das ist also schon fast verheerend. Ich hatte vorher hier gewählt, glaube ich, diese 2700, das war regional,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_5",
      "end": 26.0,
      "speaker": "A",
      "start": 24.3,
      "text": " das war übers Wasser.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_6",
      "end": 29.434,
      "speaker": "A",
      "start": 26.484,
      "text": " Dann dockt sie jetzt ein automatischer Beantworter durch,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_7",
      "end": 31.884,
      "speaker": "A",
      "start": 29.534,
      "text": " der sagt, dann wählen sie die 1, dann wählen sie die 2,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_8",
      "end": 32.434,
      "speaker": "A",
      "start": 31.984,
      "text": " wählen sie 3.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_9",
      "end": 33.234,
      "speaker": "A",
      "start": 32.484,
      "text": " Alles war es nicht.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_10",
      "end": 36.234,
      "speaker": "A",
      "start": 33.484,
      "text": " Dann wählen sie, bleiben sie in der Leitung, wählen sie die 4.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_11",
      "end": 39.634,
      "speaker": "A",
      "start": 36.484,
      "text": " Dann wählen sie die 4, dann fängt das Gerät wieder von vorne an.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_12",
      "end": 40.584,
      "speaker": "A",
      "start": 39.684000000000005,
      "text": " Das war die eine Sache.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_13",
      "end": 41.784000000000006,
      "speaker": "A",
      "start": 40.684000000000005,
      "text": " Das habe ich dreimal probiert,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_14",
      "end": 42.584,
      "speaker": "A",
      "start": 41.834,
      "text": " das war gar nichts.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_15",
      "end": 44.284000000000006,
      "speaker": "A",
      "start": 42.984,
      "text": " Jetzt sind Sie mit,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_16",
      "end": 46.134,
      "speaker": "A",
      "start": 44.334,
      "text": " wie sagt man,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_17",
      "end": 48.134,
      "speaker": "A",
      "start": 46.184000000000005,
      "text": " mit freudiger oder mit freundlicher",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_18",
      "end": 48.784000000000006,
      "speaker": "agent",
      "start": 48.134,
      "text": " Jaaaaa!",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_19",
      "end": 49.334,
      "speaker": "A",
      "start": 48.784000000000006,
      "text": " Stimme,",
      "type": "transcript.text.segment"
    },
