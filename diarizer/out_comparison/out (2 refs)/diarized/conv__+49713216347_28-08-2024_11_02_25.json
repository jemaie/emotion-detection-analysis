      "id": "seg_43",
      "end": 109.1,
      "speaker": "A",
      "start": 107.14999999999999,
      "text": " da können Sie einen Hilfsarbeiter dazu nehmen. Ist",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_44",
      "end": 109.14999999999999,
      "speaker": "agent",
      "start": 109.1,
      "text": " nee,",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_45",
      "end": 109.44999999999999,
      "speaker": "A",
      "start": 109.14999999999999,
      "text": " ja Ihr selber.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_46",
      "end": 111.6,
      "speaker": "agent",
      "start": 109.44999999999999,
      "text": " nicht meine, die Abteilung, die halt für",
