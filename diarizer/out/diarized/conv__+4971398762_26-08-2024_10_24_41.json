    {
      "id": "seg_1",
      "end": 4.3500000000000005,
      "speaker": "B",
      "start": 1.4500000000000004,
      "text": " Können Sie sich bitte die ERV-Stelle fragen?",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_2",
      "end": 8.450000000000001,
      "speaker": "A",
      "start": 5.750000000000001,
      "text": " Frau Nagel ist momentan bei uns nicht im Haus.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_3",
      "end": 11.350000000000001,
      "speaker": "B",
      "start": 9.100000000000001,
      "text": " Und jemand anderes von der ERV-Stelle?",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_4",
      "end": 16.8,
      "speaker": "A",
      "start": 12.650000000000002,
      "text": " Müsste ich mal geschwind gucken, weil eigentlich hat sie gar keine Vertretung.",
      "type": "transcript.text.segment"
    },
    {
      "id": "seg_5",
      "end": 20.650000000000002,
      "speaker": "B",
      "start": 17.55,
      "text": " Okay, und braucht man dann einen Termin, wenn man was machen will?",
